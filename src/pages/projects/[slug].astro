---
import Layout from '../../layouts/Layout.astro';
import { getProjectNotebookUrl } from '../../data/projects';

export async function getStaticPaths() {
  const { projects } = await import('../../data/projects');
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const notebookUrl = getProjectNotebookUrl(project);
---

<Layout title={project.title} description={project.description}>
  <article class="project">
    <header>
      <h1>{project.title}</h1>
      <p class="description">{project.description}</p>
    </header>

    {project.body && (
      <div class="body" set:html={project.body} />
    )}

    {notebookUrl && (
      <section class="notebook-section">
        <h2>Notebook</h2>
        <p>
          <a href={notebookUrl} target="_blank" rel="noopener noreferrer">
            Open interactive notebook ↗
          </a>
          {' '}(opens in a new tab), or view inline below:
        </p>
        <iframe
          title={project.title}
          src={notebookUrl}
          class="notebook-iframe"
        />
      </section>
    )}

    <p class="back"><a href="/projects">← All projects</a></p>
  </article>
</Layout>

<style>
  .project header {
    margin-bottom: 1.5rem;
  }

  .project .description {
    color: var(--color-muted);
    font-size: 1rem;
    margin: 0.25rem 0 0 0;
  }

  .project .body {
    margin-bottom: 2rem;
  }

  .project .body :global(p) {
    margin: 0 0 0.75rem 0;
  }

  .project .body :global(p:last-child) {
    margin-bottom: 0;
  }

  .project .body :global(code) {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .notebook-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .notebook-section h2 {
    font-size: 1.15rem;
    margin: 0 0 0.5rem 0;
  }

  .notebook-section p {
    margin: 0 0 1rem 0;
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  .notebook-section a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .notebook-section a:hover {
    text-decoration: underline;
  }

  .notebook-iframe {
    width: 100%;
    height: 70vh;
    min-height: 400px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    background: var(--color-surface);
  }

  .back {
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .back a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .back a:hover {
    color: var(--color-accent);
  }
</style>
