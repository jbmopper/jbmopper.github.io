---
import Layout from '../../layouts/Layout.astro';
import { getProjectNotebookRootUrl } from '../../data/projects';

export async function getStaticPaths() {
  const { projects } = await import('../../data/projects');
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const notebookRootUrl = getProjectNotebookRootUrl(project);
---

<Layout title={project.title} description={project.description}>
  <article class="project">
    <header>
      <h1>{project.title}</h1>
      <p class="description">{project.description}</p>
    </header>

    {project.body && (
      <div class="body" set:html={project.body} />
    )}

    {notebookRootUrl && (
      <section class="notebook-section">
        <h2>Notebooks</h2>
        <p class="notebook-intro">
          Open the root notebook (landing page); from there you can follow links to other notebooks in this project.
        </p>
        <a href={notebookRootUrl} target="_blank" rel="noopener noreferrer" class="embed-link">
          Open notebook ↗
        </a>
      </section>
    )}

    <p class="back"><a href="/projects">← All projects</a></p>
  </article>
</Layout>

<style>
  .project header {
    margin-bottom: 1.5rem;
  }

  .project .description {
    color: var(--color-muted);
    font-size: 1rem;
    margin: 0.25rem 0 0 0;
  }

  .project .body {
    margin-bottom: 2rem;
  }

  .project .body :global(p) {
    margin: 0 0 0.75rem 0;
  }

  .project .body :global(p:last-child) {
    margin-bottom: 0;
  }

  .project .body :global(code) {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .notebook-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .notebook-section h2 {
    font-size: 1.15rem;
    margin: 0 0 0.5rem 0;
  }

  .notebook-intro {
    font-size: 0.95rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem 0;
  }

  .embed-link {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 1rem;
  }

  .embed-link:hover {
    text-decoration: underline;
  }

  .back {
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .back a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .back a:hover {
    color: var(--color-accent);
  }
</style>
