---
import Layout from '../../layouts/Layout.astro';
import { getProjectEmbeds, embedUrl } from '../../data/projects';

export async function getStaticPaths() {
  const { projects } = await import('../../data/projects');
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const embeds = getProjectEmbeds(project);
---

<Layout title={project.title} description={project.description}>
  <article class="project">
    <header>
      <h1>{project.title}</h1>
      <p class="description">{project.description}</p>
    </header>

    {project.body && (
      <div class="body" set:html={project.body} />
    )}

    {embeds.length > 0 && (
      <section class="embeds-section">
        <h2>Notebooks</h2>
        <ul class="embed-links">
          {embeds.map((embed) => {
            const url = embedUrl(embed);
            const label = embed.title ?? project.title;
            return (
              <li>
                <a href={url} target="_blank" rel="noopener noreferrer" class="embed-link">
                  {label} ↗
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    <p class="back"><a href="/projects">← All projects</a></p>
  </article>
</Layout>

<style>
  .project header {
    margin-bottom: 1.5rem;
  }

  .project .description {
    color: var(--color-muted);
    font-size: 1rem;
    margin: 0.25rem 0 0 0;
  }

  .project .body {
    margin-bottom: 2rem;
  }

  .project .body :global(p) {
    margin: 0 0 0.75rem 0;
  }

  .project .body :global(p:last-child) {
    margin-bottom: 0;
  }

  .project .body :global(code) {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .embeds-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .embeds-section h2 {
    font-size: 1.15rem;
    margin: 0 0 0.75rem 0;
  }

  .embed-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .embed-links li {
    margin-bottom: 0.5rem;
  }

  .embed-link {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 1rem;
  }

  .embed-link:hover {
    text-decoration: underline;
  }

  .back {
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .back a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .back a:hover {
    color: var(--color-accent);
  }
</style>
