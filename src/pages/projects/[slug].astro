---
import Layout from '../../layouts/Layout.astro';
import { getProjectEmbeds, embedUrl } from '../../data/projects';

export async function getStaticPaths() {
  const { projects } = await import('../../data/projects');
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const embeds = getProjectEmbeds(project);
---

<Layout title={project.title} description={project.description}>
  <article class="project">
    <header>
      <h1>{project.title}</h1>
      <p class="description">{project.description}</p>
    </header>

    {project.body && (
      <div class="body" set:html={project.body} />
    )}

    {embeds.map((embed) => {
      const url = embedUrl(embed);
      const height = embed.height ?? 'min(420px, 50vh)';
      return (
        <section class="embed-section">
          <div class="embed-header">
            {embed.title && <h2>{embed.title}</h2>}
            <a href={url} target="_blank" rel="noopener noreferrer" class="embed-open">
              Open in new tab ↗
            </a>
          </div>
          <iframe
            title={embed.title ?? project.title}
            src={url}
            class="embed-iframe"
            style={`height: ${height}`}
          />
        </section>
      );
    })}

    <p class="back"><a href="/projects">← All projects</a></p>
  </article>
</Layout>

<style>
  .project header {
    margin-bottom: 1.5rem;
  }

  .project .description {
    color: var(--color-muted);
    font-size: 1rem;
    margin: 0.25rem 0 0 0;
  }

  .project .body {
    margin-bottom: 2rem;
  }

  .project .body :global(p) {
    margin: 0 0 0.75rem 0;
  }

  .project .body :global(p:last-child) {
    margin-bottom: 0;
  }

  .project .body :global(code) {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .embed-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .embed-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .embed-section h2 {
    font-size: 1.15rem;
    margin: 0;
  }

  .embed-open {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .embed-open:hover {
    text-decoration: underline;
  }

  .embed-iframe {
    width: 100%;
    min-height: 280px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    background: var(--color-surface);
  }

  .back {
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .back a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .back a:hover {
    color: var(--color-accent);
  }
</style>
